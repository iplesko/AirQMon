[Unit]
Description=AirQMon Display Service
After=network.target

[Service]
Type=simple
User=admin
WorkingDirectory=/home/admin/airqmon/backend
ExecStart=/home/admin/airqmon/backend/venv/bin/python /home/admin/airqmon/backend/display.py --db /home/admin/airqmon/backend/data.db --interval 5
ExecStopPost=+/usr/bin/pinctrl set 18 op dl pd
Restart=on-failure

[Install]
WantedBy=multi-user.target
