# Shared runtime settings used by the systemd wrapper installed by install_systemd.sh.

AIRQMON_BACKEND_DIR=/home/admin/airqmon/backend
AIRQMON_PYTHON=/home/admin/airqmon/backend/venv/bin/python
AIRQMON_DB_PATH=/home/admin/airqmon/backend/data.db
AIRQMON_APP_ENV_FILE=/home/admin/airqmon/backend/.env

AIRQMON_WEB_HOST=0.0.0.0
AIRQMON_WEB_PORT=8000

AIRQMON_POLL_INTERVAL=5

AIRQMON_DISPLAY_BRIGHTNESS_GPIO=18
AIRQMON_PINCTRL=/usr/bin/pinctrl
